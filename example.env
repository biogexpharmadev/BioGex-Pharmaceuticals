# Google Sheets Configuration
# The email address of the Google Service Account
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account-email@project-id.iam.gserviceaccount.com

# The private key of the Google Service Account (include the BEGIN/END PRIVATE KEY lines)
# When pasting in .env, you can use \n for newlines if necessary, but typically standard format works in recent Next.js
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"

# The ID of the Google Sheet containing product data
SPREADSHEET_ID=your_spreadsheet_id_here

# The name of the specific sheet/tab to read from (defaults to Sheet1 if not set)
SHEET_NAME=Sheet1

# SMTP Configuration for Emails (Contact Form, Quote Requests & Newsletter)
# Delivers to the Zoho Mail inbox at info@biogexpharma.com
# Zoho Mail SMTP host (use smtp.zoho.eu / smtp.zoho.in etc. if the mailbox is on a regional data center)
SMTP_HOST=smtp.zoho.com

# Port for SMTP (465 for SSL)
SMTP_PORT=465

# Zoho Mail account used to send (typically info@biogexpharma.com)
SMTP_USER=info@biogexpharma.com

# Zoho Mail password or app-specific password for SMTP authentication
SMTP_PASSWORD=your_zoho_smtp_password

